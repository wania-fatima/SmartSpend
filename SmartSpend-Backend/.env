# ===============================
# SmartSpend Project - Environment
# ===============================

# MongoDB Database
MONGO_URI=mongodb://localhost:27017/SmartSpend  # Local MongoDB or Atlas URI

# JWT Secret for authentication
JWT_SECRET=SmartSpend-project123  # Strong secret string

# Backend Port
PORT=5000

# Frontend URL (React app)
FRONTEND_URL=http://localhost:3000

# ===============================
# Email Configuration (Mailtrap)
# ===============================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your-mailtrap-username      # Replace with your actual Mailtrap username
MAIL_PASS=your-mailtrap-password      # Replace with your actual Mailtrap password

# ===============================
# Node Environment
# ===============================
NODE_ENV=development
